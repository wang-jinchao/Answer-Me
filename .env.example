# Example environment variables. Do NOT put real credentials in this file when committing.
# In CI (GitHub Actions) set these as repository secrets and pass them as env vars.

# ACCOUNTS_JSON should be a JSON string. Example:
# ACCOUNTS_JSON='[{"name":"user001","username":"RS2789","password":"REPLACE_ME"}]'

# TARGET_URL is the page your automation should navigate to
# TARGET_URL=https://www.upfitapp.com/year2024/rsbindex0823

# Optional: number of workers to run in parallel (default 4)
# MAX_WORKERS=4
